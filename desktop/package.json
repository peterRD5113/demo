{
  "name": "contract-risk-management",
  "productName": "Contract Risk Management",
  "version": "1.0.0",
  "description": "合同風險管理系統 - 智能識別合同風險",
  "main": "dist/main/index.js",
  "author": "Contract Risk Management Team",
  "license": "MIT",
  "scripts": {
    "start": "electron-forge start",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:renderer": "vite build --config vite.renderer.config.mjs",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:win": "npm run build && electron-forge make --platform=win32",
    "make:mac": "npm run build && electron-forge make --platform=darwin",
    "make:linux": "npm run build && electron-forge make --platform=linux",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "test": "jest --coverage --verbose",
    "test:unit": "jest unit_tests/ --verbose",
    "test:api": "jest API_tests/ --verbose",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "electron",
    "desktop",
    "contract",
    "risk-management",
    "document-analysis"
  ],
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "antd": "^6.3.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "crypto-js": "^4.2.0",
    "docx": "^8.5.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "pdfkit": "^0.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sql.js": "^1.8.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/../unit_tests",
      "<rootDir>/../API_tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/renderer/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@main/(.*)$": "<rootDir>/src/main/$1",
      "^@renderer/(.*)$": "<rootDir>/src/renderer/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@preload/(.*)$": "<rootDir>/src/preload/$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "types": [
              "jest",
              "node"
            ]
          }
        }
      ]
    }
  }
}
