{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["../desktop/src/*"],
      "@main/*": ["../desktop/src/main/*"],
      "@shared/*": ["../desktop/src/shared/*"],
      "@renderer/*": ["../desktop/src/renderer/*"]
    },
    "typeRoots": ["../desktop/node_modules/@types", "../node_modules/@types"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
